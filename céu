<!--============================== css ==============================-->
<style>

*{box-sizing:border-box;}
*:not(a),
::before,
::after{transition:background .3s, border .3s}

:root {
    /*colors*/
    --background-color:{RGBcolor:background};
    
    --text:{RGBcolor:text};
    --link:{RGBcolor:link};
    --link-hover:{RGBcolor:link hover};
    --title:{RGBcolor:title};
    --sub-title:{RGBcolor:sub text};
    --sub-title-hover:{RGBcolor:sub text hover};
    
    --accent:{RGBcolor:accent};
    
    --borders:{RGBcolor:borders};
    --shadows:{RGBcolor:shadows};
    --scrollbar:{RGBcolor:scrollbar};
    
    --main-boxes:{RGBcolor:main boxes};
    --inner-boxes:{RGBcolor:inner boxes};
    --inner-text:{RGBcolor:inner text};
    --header:{RGBcolor:header};
    
    --user-color:{RGBcolor:user color};
    --user-background:{RGBcolor:user background};
    
    /*images*/
    
    /*fonts*/
    
    --main-font:'{text:Font}';
    --title-font:'{text:Title font}';
    --font-size:{select:font size};
    
    /*npf set*/
    --NPF-Caption-Spacing:1em;
    --NPF-Image-Spacing:1px;
    
    /*content adjustments*/
    --gap:100px;
    --posts-width:500px;
    --sidebar-width:250px;
    --main-width:calc(var(--sidebar-width) + var(--gap) + var(--posts-width));
    
    --border-radius:{text:border radius};
}

.poll-post {
    --Poll-Question-Font-Size:1em;
    
    --Poll-Option-Background-Color:transparent;
    --Poll-Option-Corner-Rounding:var(--border-radius);
    --Poll-Option-Border-Size:2px;
    --Poll-Option-Border-Color:rgb(var(--borders));
    --Poll-Option-Padding:10px 18px;
    --Poll-Option-Font-Size:1em;
    --Poll-Option-Spacing: 10px;
    --Poll-Option-Text-Color: rgb(var(--sub-title));
    
    --Poll-Option-HOVER-Border-Color:rgb(var(--borders));
    --Poll-Option-HOVER-Background-Color:rgb(var(--borders));
    --Poll-Option-HOVER-Text-Color:rgb(var(--sub-title-hover));
    --Poll-Option-HOVER-Speed: .05s;
}

.npf-audio-wrapper {
    --NPF-Audio-Buttons-Size:18px;
    --NPF-Audio-Buttons-Color:rgb(var(--title)); /* color of play & pause buttons */
    --NPF-Audio-Buttons-Spacing:0; /* space between buttons and song info */
    
    --NPF-Audio-Image-Size:90px;
    --NPF-Audio-Image-Spacing: 0px; /* gap between player info and cover image */
}

.poll-post a.poll-row{
    font-family:var(--title-font);
    border-style:dashed !important;
}

/*basic css*/

body{
    margin:0;
	padding:0;
    height:100%;
    overflow-x:hidden;
    word-break:break-word;
    color:rgb(var(--text));
    background-color:rgb(var(--background-color));
    font:400 var(--font-size)/1.6 var(--main-font), sans-serif;
}

body.loaded{opacity:1;}

:focus{
    border:0;
    outline:0;
}

a{
    text-decoration:none;
    color:rgb(var(--link));
}

.question-header a,
.blog-description a,
li.note span.action a,
.original a:not(a[class]),
ol.notes li.note blockquote a,
.reblog-content a:not(a[class]){border-bottom:2px dashed rgb(var(--accent));}

.question-header a:hover,
.blog-description a:hover,
li.note span.action a:hover,
.original a:not(a[class]):hover,
ol.notes li.note blockquote a:hover,
.reblog-content a:not(a[class]):hover{border-bottom-style:solid;}

a:not([class]), 
a:hover{
    cursor:pointer;
    transition:ease .3s;
    text-decoration:none;
    -moz-transition:ease .3s;
    -webkit-transition:ease .3s;
}

a.credits svg{
    transition:ease .3s;
    -moz-transition:ease .3s;
    -webkit-transition:ease .3s;
}
 
a.credits:hover svg{
    fill:rgb(255, 249, 64);
    color:rgb(255, 249, 64);
    filter:drop-shadow(0 0 4px rgb(255, 249, 64));
}

a.cuscuz{
    top:20px;
    z-index:9;
    right:20px;
    position:fixed;
}

b, 
strong{font-weight:700;}

b,
i,
u,
s,
strike{color:rgb(var(--accent));}

small,
sub,
sup{font-size:.7em;}

big{font-size:1.1em;}

p {margin:.5em 0;}

h1, 
h2, 
h3, 
h4 {
    margin:1em 0;
    font-weight:700;
}

h1:first-of-type, 
h2:first-of-type, 
h3:first-of-type, 
h4:first-of-type {margin-top:0;}

blockquote{
    padding:0 0 0 20px;
    margin:.5em 0 .5em 30px;
    border-left:2px solid rgb(var(--borders));
}

pre{
    margin:.5em 0;
    display:block;
    user-select:all;
    -ms-user-select:all;
    white-space:pre-wrap;
    -webkit-user-select:all;
}

code{
    margin:0;
    display:inline;
}

ul,
ol{
    margin:.5em 0;
    padding-left:40px;
}

ol{list-style:lower-alpha;}

ul li::marker,
ol li::marker{color:rgb(var(--accent));}

p:first-child,
ul:first-child,
ol:first-child,
pre:first-child,
blockquote:first-child{margin-top:0;}

p:last-child,
ul:last-child,
ol:last-child,
pre:last-child,
blockquote:last-child{margin-bottom:0;}

hr {
    width:100%;
    height:1px;
    border:none;
    box-shadow:0;
    margin-block:20px;
    background:rgb(var(--borders));
}

/*selection*/
::selection {
    color:rgb(var(--accent));
    background-color:rgb(var(--background-color));
}

::-moz-selection {
    color:rgb(var(--accent));
    background-color:rgb(var(--background-color));
}

/*tumblr controls*/

.tmblr-iframe{
    top:10px!important;
    transition:ease .3s;
    right:10px!important;
    z-index:12!important;
    -moz-transition:ease .3s;
    transform-origin:right top;
    -webkit-transition:ease .3s;
    transform:scale(0.6)!important;
    -moz-transform:scale(0.6)!important;
    -webkit-transform:scale(0.6)!important;
}

.tmblr-iframe--follow-teaser, 
.tmblr-iframe--app-cta-button{display:none !important;}

/*tooltip*/
#s-m-t-tooltip{
    font-size:11px;
    z-index:9999999;
    max-width:300px;
    font-weight:700;
    position:relative;
    border-radius:5px;
    letter-spacing:1px;
    padding:.5em 1.5em;
    margin:0 14px 7px 30px;
    -moz-border-radius:5px;
    color:rgb(255,255,255);
    text-transform:uppercase;
    -webkit-border-radius:5px;
    background:rgba(0,0,0,.85);
}

/*scrollbar*/
::-webkit-scrollbar{
    width:15px;
    height:15px;
    padding:5px;
    background-color:rgb(var(--background-color));
}
 
::-webkit-scrollbar-thumb {
    border-radius:10px;
    background-clip:padding-box;
    border:5px solid transparent;
    background-color:rgb(var(--scrollbar));
}

/*lightboxes*/
img{
    height:auto;
    display:block;
    max-width:100%;
}

iframe{display:block;}

.vignette, 
#vignette {opacity:0;}

.lightbox-image, 
#tumblr_lightbox img {
    box-shadow:none !important;
    border-radius:var(--border-radius)!important;
    max-width:none;
    border:2px dashed rgb(var(--borders))!important;
}

.tmblr-lightbox, 
#tumblr_lightbox {background:rgba(var(--background-color),.9) !important;}

.lightbox-caption, 
#tumblr_lightbox_caption {visibility:hidden;}

.npf_row figure{cursor:pointer;}

.npf_row figure:focus{outline:0;}

/*-============================== main ==============================-*/

main{
    display:grid;
    gap:var(--gap);
    margin:100px auto;
	align-items:start;
    width:var(--main-width);
    grid-template-columns:var(--posts-width) var(--sidebar-width);
}

aside, #posts{grid-row-start:2;}

/*-============================== header ==============================-*/

header{
    display:grid;
    position:relative;
    grid-column:span 2;
}

.header-image{
    height:290px;
    border-radius:15px;
    background-size:cover;
    background-position:{select:Header image centering};
    background-color:rgb(var(--header));
    background-image:url({image:Header image});
}

.header-menu{
    gap:10px;
    height:70px;
    display:flex;
    align-self:start;
    position:absolute;
    align-items:center;
    justify-self:start;
    padding:0 15px 15px 0;
    border-bottom-right-radius:15px;
    background-color:rgb(var(--background-color));
}

img.blog-icon{
    width:55px;
    height:55px;
    border-radius:15px;
}

a.cuscuz,
.header-menu a{
    width:40px;
    height:40px;
    display:grid;
    place-items:center;
    border:2px solid rgb(var(--borders));
    background-color:rgb(var(--main-boxes));
    box-shadow:3px 3px 0 rgb(var(--shadows));
    border-radius:calc(var(--border-radius)/2);
}

a.cuscuz svg,
.header-menu a svg{
    width:20px;
    height:20px;
}

.header-menu::after,
.header-menu::before,
.blog-title::after,
.blog-title::before{
    width: 15px;
    height:15px;
    content: '';
    position:absolute;
    background-image:radial-gradient(circle at 15px 0%, transparent 0%, transparent 15px, rgb(var(--background-color)) 15px);
}

.header-menu::after,
.header-menu::before{transform:rotate(90deg);}

.blog-title::after,
.blog-title::before{transform:rotate(-90deg);}

.header-menu::before{
    top:0;
    right:-15px;
}

.header-menu::after{
    left:0;
    bottom:-15px;
}

.blog-title{
    align-self:end;
    font-weight:700;
    justify-self:end;
    font-size:1.5em;
    position:absolute;
    padding:15px 0 0 15px;
    border-top-left-radius:15px;
    font-family:var(--title-font);
    background-color:rgb(var(--background-color));
}

.blog-title::before{
    right:0;
    top:-15px;
}

.blog-title::after{
    bottom:0;
    left:-15px;
}

.blog-title a{
    padding:5px 15px;
    border-radius:var(--border-radius);
    border:2px solid rgb(var(--borders));
    background-color:rgb(var(--main-boxes));
    box-shadow:7px 7px 0 rgb(var(--shadows));
}
/*-============================== sidebar ==============================-*/

aside{
    top:50px;
    position:sticky;
    grid-column-start:2;
}


.sidebar > section{
    padding:20px;
    position:relative;
    margin-bottom:50px;
    border-radius:var(--border-radius);
    border:2px solid rgb(var(--borders));
    background-color:rgb(var(--main-boxes));
    box-shadow:7px 7px 0 rgb(var(--shadows));
}

.blog-user{
    line-height:1;
    overflow:hidden;
    margin-top:-45px;
    padding:10px 15px;
    position:absolute;
    white-space:nowrap;
    text-overflow:ellipsis;
    max-width:calc(100% - 40px);
    color:rgb(var(--user-color));
    font-family:var(--title-font);
    border-radius:calc(var(--border-radius)/2);
    background-color:rgb(var(--user-background));
}

.blog-description{
    padding:15px;
    margin-top:10px;
    border-radius:var(--border-radius);
    border:2px dashed rgb(var(--borders));
}

#menu{
    gap:15px;
    display:grid;
    grid-template-columns:1fr 1fr;
}

#menu a{
    gap:10px;
    align-items:center;
    display:inline-flex;
}

#menu a::before{
    font-size:1em;
    flex-shrink:0;
    transition:all .45s;
    font-family:'tabler-icons';
}

#menu a:nth-of-type(odd)::before{content:'\ea76'}
#menu a:nth-of-type(even)::before{content:'\eb2e'}

#menu > *:hover::before,
#menu form:focus-within{color:rgb(var(--link-hover));}

form.search{
    gap:10px;
    display:flex;
    margin-top:10px;
    align-items:center;
    grid-column:span 2;
}

.blog-description + form{margin-top:15px;}

form.search input{
    margin:0;
    width:100%;
    font:inherit;
    display:block;
    padding:2px 10px;
    background:transparent;
    text-transform:lowercase;
    border-radius:var(--border-radius);
    border:2px dashed rgb(var(--borders));
}

form.search input::placeholder {
	transition:all .3s;
    color:rgb(var(--link));
	-moz-transition:all .3s;
	-webkit-transition:all .3s;
}
 
form.search input:focus::-moz-placeholder{opacity:0;}
form.search input:focus::-moz-placeholder{opacity:0;}
form.search input:focus:-ms-input-placeholder{opacity:0;}
form.search input:focus::-webkit-input-placeholder{opacity:0;}


/*-============================== posts ==============================-*/

#posts{
    display:grid;
    gap:var(--gap);
}

.post{
    border-radius:var(--border-radius);
    border:2px solid rgb(var(--borders));
    background-color:rgb(var(--main-boxes));
    box-shadow:7px 7px 0 rgb(var(--shadows));
}

.entry{
    gap:30px;
    padding:30px;
    display:grid;
}

/*captions*/

h1.post-title,
.reblog-content > h1:first-of-type{
    color:rgb(var(--title));
    font-family:var(--title-font);
}

.reblogs,
.post.npf-post.photo-post .caption{
    gap:30px;
    display:grid;
}

.reblogs + .reblogs{margin-top:30px;}

.reblog-header{
    gap:30px;
    display:flex;
    align-items:center;
}

.reblog-header .user{
    font-weight:700;
    font-family:var(--title-font);
}

/*photo*/

.photo,
.npf_inst{
    overflow:hidden;
    position:relative;
    border-radius:var(--border-radius);
}

.photo img{width:100%;}

.npf_inst{overflow:hidden;}

/*ask*/

.ask,
.answer{
    gap:20px;
    display:grid;
    grid-template-columns:52px 1fr;
}

.ask{grid-template-columns:52px 1fr;}

.answer{grid-template-columns:1fr 52px;}

.ask img,
.answer img{
    width:52px;
    height:52px;
    border-radius:var(--border-radius);
    border:2px solid rgb(var(--borders));
}

div.asker,
div.answerer{
    font-weight:700;
    text-transform:lowercase;
}

div.asker a{color:rgb(var(--inner-text));}

.question{
    padding:20px;
    color:rgb(var(--inner-text));
    border-radius:var(--border-radius);
    background-color:rgb(var(--inner-boxes));
}

.response{
    padding:20px;
    border-radius:var(--border-radius);
    border:2px dashed rgb(var(--borders));
}

/*link*/

div.npf-link-block:first-of-type {
    margin-top:0;
    padding:20px;
    color:rgb(var(--sub-title));
    font-family:var(--title-font);
    border:2px solid rgb(var(--borders));
    border-radius:calc(var(--border-radius)/2);
}

div.npf-link-block > a{border-bottom:0!important;}

/*audio*/

.audio{
    gap:20px;
    display:grid;
    grid-template-columns:115px 1fr;
}

.audio_player{
    grid-column:span 2;
}

img.album-art{border-radius:var(--border-radius);}

.audio_info{
    gap:5px;
    display:grid;
    padding:20px;
    align-content:center;
    color:rgb(var(--inner-text));
    border-radius:var(--border-radius);
    background-color:rgb(var(--inner-boxes));
}

span.track{font-weight:700;}

.player{
    gap:20px;
    display:flex;
    line-height:1;
    align-items:center;
    margin-bottom:20px;
    justify-content:center;
}

.player svg{
    width:35px;
    height:35px;
    padding:5px;
    display:grid;
    place-items:center;
    color:rgb(var(--inner-boxes));
    border:2px solid rgb(var(--inner-boxes));
    border-radius:calc(var(--border-radius) / 2);
}

.seekbar {
    bottom:0;
	width:100%;
    height:6px;
    overflow:hidden;
    border-radius:10px;
    border:2px solid rgb(var(--inner-boxes));
}

.seekbar_progress {
	width:0;
	height:100%;
	background-color:rgb(var(--inner-boxes));
}

.npf-audio-wrapper {
    --NPF-Audio-Buttons-Size:14px;
    --NPF-Audio-Buttons-Color:rgb(var(--inner-text)); /* color of play & pause buttons */
    --NPF-Audio-Buttons-Spacing:0; /* space between buttons and song info */
 
    --NPF-Audio-Image-Size:115px;
    --NPF-Audio-Image-Spacing:0; /* gap between player info and cover image */
}

.npf-audio-wrapper{
    gap:20px;
    flex-direction:row-reverse;
}

img.npf-audio-image{border-radius:var(--border-radius);}

.npf-audio-background{
    gap:20px;
    padding:20px;
    color:rgb(var(--inner-text));
    border-radius:var(--border-radius);
    background-color:rgb(var(--inner-boxes));
}

/*post info*/

.tags{
    gap:10px;
    display:flex;
    margin:0 -30px;
    flex-wrap:wrap;
    padding:30px 30px 0 30px;
    border-top:2px dashed rgb(var(--borders));
}

.post-footer,
.post-header{
    gap:20px;
    display:flex;
    align-items:start;
    padding-inline:30px;
}

.post-header{margin-top:-15px;}

.post-footer{
    margin-bottom:-15px;
    justify-content:space-between;
}

.post-header img,
.reblog-header img,
li.note img.avatar{
    width:36px;
    height:36px;
    border:2px solid rgb(var(--borders));
    background-color:rgb(var(--main-boxes));
    border-radius:calc(var(--border-radius)/2);
}

.tags a,
a.read_more,
.perma-info a,
a.more_notes_link{
    padding:2px 7px;
    text-transform:lowercase;
    color:rgb(var(--sub-title));
    font-family:var(--title-font);
    border:2px solid rgb(var(--accent));
    border-radius:calc(var(--border-radius)/2);
}

a.note-count,
.post-header a{
    height:36px;
    line-height:1;
    padding:0 15px;
    align-items:center;
    display:inline-flex;
    color:rgb(var(--sub-title));
    font-family:var(--title-font);
    border:2px solid rgb(var(--borders));
    background-color:rgb(var(--main-boxes));
    border-radius:calc(var(--border-radius)/2);
}

.tags a:hover,
a.read_more:hover,
a.note-count:hover,
.post-header a:hover{
    color:rgb(var(--sub-title-hover));
    background-color:rgb(var(--borders));
}

.info-buttons{
    gap:5px;
    display:flex;
}

.info-buttons a{
    width:36px;
    height:36px;
    display:grid;
    line-height:1;
    place-items:center;
    color:rgb(var(--sub-title));
    font-family:var(--title-font);
    border:2px solid rgb(var(--borders));
    background-color:rgb(var(--main-boxes));
    border-radius:calc(var(--border-radius)/2);
}

.info-buttons svg{
    width:20px;
    height:20px;
}

.like-button{overflow:hidden;}

.like-button .like_button{position:absolute;}
.like-button{position:relative;}

.like-button .like_button iframe {
    right:0;
    bottom:0;
    top:-20px;
    z-index:2;
    opacity:0;
    left:-20px;
    position:absolute;
}

.like-button svg{transition:color .3s;}

.liked ~ svg{
    z-index:1;
    position:relative;
    pointer-events:none;
    fill:rgb(var(--sub-title-hover));
    color:rgb(var(--sub-title-hover));
    background-color:rgb(var(--borders));
}

.like-button .like_button{
    top:0;
    left:0;
    width:100%;
    height:100%;
    position:absolute;
    transition:background .3s;
}

.like-button .like_button.liked{background-color:rgb(var(--borders));}

/*notes*/

ol.notes{
    gap:20px;
    margin:0;
    padding:20px;
    display:grid;
    list-style:none;
}

ol.notes li.note{
    gap:10px;
    display:flex;
    flex-wrap:wrap;
}

ol.notes span.action{
    flex:1;
    padding:10px;
    border:2px dashed rgb(var(--borders));
    border-radius:calc(var(--border-radius) / 2);
}

ol.notes blockquote{
    width:100%;
    margin-left:calc(25px/2);
}

span.notes_loading{line-height:0;}

span.notes_loading svg {
    color:rgb(var(--accent));
    -webkit-animation: rotation 2s infinite linear;
}

@-webkit-keyframes rotation {
    from {-webkit-transform: rotate(0deg);}
    to   {-webkit-transform: rotate(359deg);}
}

/*-============================== footer ==============================-*/

/*pagination*/

#pagination{
    display:grid;
    grid-column:span 2;
    justify-self:center;
    grid-template-rows:36px;
    border-radius:var(--border-radius);
    border:2px solid rgb(var(--borders));
    background-color:rgb(var(--main-boxes));
    box-shadow:7px 7px 0 rgb(var(--shadows));
    grid-template-columns:auto calc(36px*2 + 2px) 36px 1.5px 36px;
}


.current-page{
    place-self:center;
    padding-inline:15px;
    font-family:var(--title-font);
}

.pag-buttons{
    display:grid;
    grid-template-columns:36px 2px 36px;
    border-inline:2px solid rgb(var(--borders));
}

#pagination .divider{
    width:1.5px;
    background-color:rgb(var(--borders));
}

a.back,
a.credits,
.pag-buttons a{
    line-height:0;
    place-self:center;
}

.pag-buttons a:not(.active){
    cursor:text;
    opacity:.75;
}

#pagination svg{
    width:20px;
    height:20px;
}

/*-============================== mobile ==============================-*/

@media (max-width:920px){
    .tmblr-iframe{
        left:10px!important;
        transform-origin:left top!important;
    }
    
    a.cuscuz svg.icon-tabler-x,
    a.cuscuz.active svg.icon-tabler-menu-2{display:none;}
    
    a.cuscuz.active svg.icon-tabler-x{display:block;}
    
    main{
        width:90vw;
        margin:10vw auto;
        grid-template-columns:none;
    }
    
    #posts,
    header,
    footer,
    .question,
    .response,
    .audio_info{grid-column:span 2;}
    
    aside{
        top:0;
        left:0;
        z-index:1;
        width:100vw;
        height:100vh;
        display:none;
        position:fixed;
        padding:5vh 5vw;
        overflow-y:auto;
        backdrop-filter:blur(5px);
        background-color:rgb(var(--background-color),.75);
    }
    
    .sidebar:first-child{margin-top:calc(25px + 5vh);}
    
    .ask img,
     .answer img,
    img.album-art,
    a.avatar_frame,
    img.npf-audio-image{display:none;}
}

{CustomCSS}
</style>    
</head>

